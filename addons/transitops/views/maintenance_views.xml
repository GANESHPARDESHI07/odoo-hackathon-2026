<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_transitops_maintenance_list" model="ir.ui.view">
        <field name="name">view.transitops.maintenance.list</field>
        <field name="model">transitops.maintenance</field>
        <field name="arch" type="xml">
            <list string="Maintenance" decoration-success="state == 'done'" decoration-info="state == 'open'" decoration-danger="state == 'cancelled'">
                <field name="service_type"/>
                <field name="vehicle_id"/>
                <field name="date"/>
                <field name="cost" string="Cost (₹)"/>
                <field name="state" widget="badge"/>
            </list>
        </field>
    </record>

    <record id="view_transitops_maintenance_form" model="ir.ui.view">
        <field name="name">view.transitops.maintenance.form</field>
        <field name="model">transitops.maintenance</field>
        <field name="arch" type="xml">
            <form string="Maintenance">
                <header>
                    <button name="action_close" type="object" string="Close" class="btn-primary" invisible="state != 'open'"/>
                    <button name="action_cancel" type="object" string="Cancel" class="btn-secondary" invisible="state != 'open'"/>
                    <field name="state" widget="statusbar" readonly="1"/>
                </header>
                <sheet>
                    <group>
                        <field name="service_type"/>
                        <field name="vehicle_id" readonly="state != 'open'"/>
                        <field name="date"/>
                        <field name="cost" string="Cost (₹)"/>
                    </group>
                    <group>
                        <field name="description"/>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_transitops_maintenance_search" model="ir.ui.view">
        <field name="name">view.transitops.maintenance.search</field>
        <field name="model">transitops.maintenance</field>
        <field name="arch" type="xml">
            <search string="Maintenance">
                <field name="service_type"/>
                <field name="vehicle_id"/>
                <filter string="Open" name="filter_state_open" domain="[('state','=','open')]"/>
                <filter string="Done" name="filter_state_done" domain="[('state','=','done')]"/>
                <filter string="Cancelled" name="filter_state_cancelled" domain="[('state','=','cancelled')]"/>
            </search>
        </field>
    </record>

    <record id="action_transitops_maintenance" model="ir.actions.act_window">
        <field name="name">Maintenance</field>
        <field name="res_model">transitops.maintenance</field>
        <field name="view_mode">list,form</field>
        <field name="help">Create the first maintenance order for an available vehicle.</field>
    </record>

    <menuitem id="menu_transitops_maintenance" name="Maintenance" parent="transitops.menu_transitops_fleet" action="action_transitops_maintenance" sequence="20"/>
</odoo>
