<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="action_transitops_trip" model="ir.actions.act_window">
        <field name="name">Trips</field>
        <field name="res_model">transitops.trip</field>
        <field name="view_mode">list,form</field>
        <field name="help">Register and manage trips. Use Dispatch, Complete and Cancel to move trip state.</field>
    </record>

    <menuitem id="menu_transitops_trip" name="Trips" parent="menu_transitops_operations" action="action_transitops_trip" sequence="10"/>

    <record id="view_transitops_trip_tree" model="ir.ui.view">
        <field name="name">transitops.trip.list</field>
        <field name="model">transitops.trip</field>
        <field name="arch" type="xml">
            <list string="Trips">
                <field name="name"/>
                <field name="source"/>
                <field name="destination"/>
                <field name="vehicle_id"/>
                <field name="driver_id"/>
                <field name="cargo_weight_kg"/>
                <field name="state"/>
                <field name="dispatch_datetime"/>
            </list>
        </field>
    </record>

    <record id="view_transitops_trip_form" model="ir.ui.view">
        <field name="name">transitops.trip.form</field>
        <field name="model">transitops.trip</field>
        <field name="arch" type="xml">
            <form string="Trip">
                <header>
                    <button name="action_dispatch" type="object" string="Dispatch" class="btn-primary" attrs="{ 'invisible': [('state','!=','draft')]}"/>
                    <button name="action_complete" type="object" string="Complete" class="btn-success" attrs="{ 'invisible': [('state','!=','dispatched')]}"/>
                    <button name="action_cancel" type="object" string="Cancel" class="btn-secondary" attrs="{ 'invisible': [('state','in',['completed','cancelled'])]}"/>
                    <field name="state" widget="statusbar"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="source"/>
                            <field name="destination"/>
                            <field name="vehicle_id"/>
                            <field name="driver_id"/>
                        </group>
                        <group>
                            <field name="cargo_weight_kg"/>
                            <field name="vehicle_max_load_kg" readonly="1"/>
                            <field name="planned_distance_km"/>
                            <field name="revenue"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Completion">
                            <group>
                                <field name="start_odometer_km" readonly="1"/>
                                <field name="end_odometer_km" attrs="{ 'readonly': [('state','!=','dispatched')] }"/>
                                <field name="actual_distance_km" readonly="1"/>
                                <field name="fuel_consumed_l"/>
                                <field name="fuel_cost"/>
                            </group>
                        </page>
                        <page string="Notes">
                            <field name="notes"/>
                        </page>
                    </notebook>
                </sheet>
                <footer>
                    <field name="dispatch_datetime"/>
                    <field name="complete_datetime"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="view_transitops_trip_search" model="ir.ui.view">
        <field name="name">transitops.trip.search</field>
        <field name="model">transitops.trip</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="state"/>
                <field name="vehicle_id"/>
                <field name="driver_id"/>
                <filter string="Draft" name="filter_draft" domain="[('state','=','draft')]"/>
                <filter string="Dispatched" name="filter_dispatched" domain="[('state','=','dispatched')]"/>
                <filter string="Completed" name="filter_completed" domain="[('state','=','completed')]"/>
            </search>
        </field>
    </record>
</odoo>
