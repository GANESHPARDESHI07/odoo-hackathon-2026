<odoo>
    <data>
        <record id="view_trip_tree" model="ir.ui.view">
            <field name="name">transitops.trip.tree</field>
            <field name="model">transitops.trip</field>
            <field name="arch" type="xml">
                <tree>
                    <field name="name"/>
                    <field name="source"/>
                    <field name="destination"/>
                    <field name="vehicle_id"/>
                    <field name="driver_id"/>
                    <field name="cargo_weight_kg"/>
                    <field name="state"/>
                    <field name="dispatch_datetime"/>
                </tree>
            </field>
        </record>

        <record id="view_trip_form" model="ir.ui.view">
            <field name="name">transitops.trip.form</field>
            <field name="model">transitops.trip</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <group>
                            <field name="name"/>
                            <field name="source"/>
                            <field name="destination"/>
                            <field name="vehicle_id"/>
                            <field name="driver_id"/>
                            <field name="cargo_weight_kg"/>
                            <field name="planned_distance_km"/>
                            <field name="revenue"/>
                            <field name="state" readonly="1"/>
                        </group>
                        <group>
                            <field name="dispatch_datetime"/>
                            <field name="complete_datetime"/>
                            <field name="start_odometer_km"/>
                            <field name="end_odometer_km"/>
                            <field name="actual_distance_km" readonly="1"/>
                            <field name="fuel_consumed_l"/>
                            <field name="fuel_cost"/>
                            <field name="notes"/>
                        </group>
                    </sheet>
                    <footer>
                        <button name="action_dispatch" type="object" string="Dispatch" states="draft"/>
                        <button name="action_complete" type="object" string="Complete" states="dispatched"/>
                        <button name="action_cancel" type="object" string="Cancel" states="dispatched"/>
                    </footer>
                </form>
            </field>
        </record>

        <record id="action_trip" model="ir.actions.act_window">
            <field name="name">Trips</field>
            <field name="res_model">transitops.trip</field>
            <field name="view_mode">tree,form</field>
        </record>

        <menuitem id="menu_transitops_root" name="TransitOps" sequence="10"/>
        <menuitem id="menu_transitops_trip" name="Trips" parent="menu_transitops_root" action="action_trip" sequence="10"/>

        <record id="view_trip_search" model="ir.ui.view">
            <field name="name">transitops.trip.search</field>
            <field name="model">transitops.trip</field>
            <field name="arch" type="xml">
                <search>
                    <field name="state"/>
                    <field name="vehicle_id"/>
                    <field name="driver_id"/>
                </search>
            </field>
        </record>
    </data>
</odoo>